<robot name="warehouse_robot">
  <!-- BASE FOOTPRINT -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.06"/>
  </joint>
  <!-- BASE LINK -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.18" radius="0.22"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.8 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.18" radius="0.22"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.18"/>
    </inertial>
  </link>
  <!-- LEFT WHEEL -->
  <link name="left_wheel">
    <visual>
